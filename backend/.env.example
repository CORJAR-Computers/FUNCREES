# ============================================
# FUNCREES Colombia — Variables de Entorno
# ============================================
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ============================================

# --- DJANGO ---
# Modo debug (False en producción, True solo para desarrollo local)
DEBUG=False

# Clave secreta de Django — Genera una nueva con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=genera-una-clave-unica-aqui

# Hosts permitidos separados por coma (sin espacios)
# Ejemplo: funcreescolombia.org,www.funcreescolombia.org,localhost
ALLOWED_HOSTS=funcreescolombia.org,www.funcreescolombia.org,localhost,127.0.0.1

# --- BASE DE DATOS ---
# Para desarrollo local (SQLite):
# DATABASE_URL=sqlite:///db.sqlite3
#
# Para producción con PostgreSQL:
# Formato: postgresql://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgresql://funcrees_user:tu_password_segura@localhost:5432/funcrees_db

# --- CORS ---
# Orígenes permitidos para CORS (separados por coma, sin espacios)
# Ejemplo: https://funcreescolombia.org,https://www.funcreescolombia.org,http://localhost:5500
CORS_ALLOWED_ORIGINS=https://funcreescolombia.org,https://www.funcreescolombia.org

# --- FRONTEND ---
# URL del frontend (para redirecciones de pago y enlaces en emails)
FRONTEND_URL=https://funcreescolombia.org

# --- EMAIL (SMTP) ---
# Usando Gmail como ejemplo — recomiendo SendGrid, Mailgun o el servicio de Hostinger
DEFAULT_FROM_EMAIL=contacto@funcreescolombia.org
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicacion
EMAIL_USE_TLS=True

# --- WOMPI (Pasarela de Pagos) ---
# Ambiente: 'sandbox' para pruebas, 'production' para producción real
WOMPI_ENV=sandbox

# Obtén tus llaves en: https://wompi.co
WOMPI_PUBLIC_KEY=pub_prod_xxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_prod_xxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=prod_integrity_xxxxxxxxxxxx

# --- ENCRIPTACIÓN (Fernet - Ley 1581 Habeas Data) ---
# Genera una clave con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=tu-clave-fernet-de-44-caracteres-base64-aqui
